<Window x:Class="MediaControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaControl" Height="180" Width="340"
        WindowStyle="None" AllowsTransparency="true" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" MouseLeave="Window_MouseLeave">
    
    <Border Name="MainBorder" CornerRadius="15" Background="#121212" BorderBrush="#333333" BorderThickness="1.5" Margin="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/> <ColumnDefinition Width="*"/>   <ColumnDefinition Width="40"/>  </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="10">
                <Border CornerRadius="10" ClipToBounds="True">
                    <Image Name="AlbumArt" Stretch="UniformToFill" Source="pack://siteoforigin:,,,/default_cover.png"/>
                </Border>
                <Image Name="AppIcon" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="0"/>
                    </Image.Effect>
                </Image>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                <TextBlock Name="SourceLabel" Text="APP.EXE" Foreground="#1DB954" FontSize="10" FontWeight="Bold"/>
                <TextBlock Name="TitleLabel" Text="Song Title" Foreground="White" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Name="ArtistLabel" Text="Artist Name" Foreground="Gray" FontSize="12" TextTrimming="CharacterEllipsis"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="⏮" Click="Prev_Click" Style="{StaticResource MediaBtn}"/>
                    <Button Name="PlayBtn" Content="⏯" Click="Play_Click" Style="{StaticResource PlayBtnStyle}"/>
                    <Button Content="⏭" Click="Next_Click" Style="{StaticResource MediaBtn}"/>
                </StackPanel>
            </StackPanel>

            <Slider Grid.Column="2" Name="VolSlider" Orientation="Vertical" Minimum="0" Maximum="100" 
                    Margin="0,15" ValueChanged="VolSlider_ValueChanged"
                    Foreground="#1DB954" Background="#333333"/>
        </Grid>
    </Border>
</Window>
