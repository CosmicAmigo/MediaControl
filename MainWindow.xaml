<Window x:Class="MediaControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Control" Height="160" Width="380"
        WindowStyle="None" AllowsTransparency="true" Background="Transparent"
        Topmost="True" ShowInTaskbar="True">
    
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="Media Control Now Playing"/>
    </Window.TaskbarItemInfo>

    <Border CornerRadius="15" Background="#121212" BorderBrush="#333333" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/> <ColumnDefinition Width="*"/>   <ColumnDefinition Width="45"/>  </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="10">
                <Border CornerRadius="8" ClipToBounds="True">
                    <Image Name="AlbumArt" Stretch="UniformToFill" Source="pack://siteoforigin:,,,/default.png"/>
                </Border>
                <Image Name="AppIcon" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5"/>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Name="TitleLabel" Text="Track Title" Foreground="White" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Name="ArtistLabel" Text="Artist - Album" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="🔀" Name="ShufBtn" Style="{StaticResource MiniBtn}"/>
                    <Button Content="⏮" Style="{StaticResource MiniBtn}"/>
                    <Button Content="⏯" Width="45" Background="#1DB954" Foreground="Black"/>
                    <Button Content="⏭" Style="{StaticResource MiniBtn}"/>
                    <Button Content="🔁" Name="RepBtn" Style="{StaticResource MiniBtn}"/>
                </StackPanel>
            </StackPanel>

            <Slider Grid.Column="2" Orientation="Vertical" Margin="10,20" Foreground="#1DB954"/>
        </Grid>
    </Border>
</Window>
